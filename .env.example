# =============================================================================
# Copie este arquivo para .env e preencha os valores antes de rodar:
#   cp .env.example .env
#
# O arquivo .env NUNCA deve ser commitado (está no .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL — banco de metadados do Airflow
# -----------------------------------------------------------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=SUBSTITUA_POR_SENHA_SEGURA
POSTGRES_DB=airflow

# -----------------------------------------------------------------------------
# Airflow — segurança
#
# Gerar fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Gerar secret key (qualquer string aleatória longa):
#   python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
AIRFLOW__CORE__FERNET_KEY=SUBSTITUA_POR_FERNET_KEY_GERADA
AIRFLOW__WEBSERVER__SECRET_KEY=SUBSTITUA_POR_SECRET_KEY_GERADA

# -----------------------------------------------------------------------------
# Airflow — usuário admin (criado na primeira inicialização)
# -----------------------------------------------------------------------------
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=SUBSTITUA_POR_SENHA_SEGURA
AIRFLOW_ADMIN_EMAIL=seu@email.com

# -----------------------------------------------------------------------------
# GCP
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=anac-flight-pipeline

# -----------------------------------------------------------------------------
# UID do processo Airflow dentro do container (padrão da imagem oficial: 50000)
# Em Linux, ajuste para seu UID local: AIRFLOW_UID=$(id -u)
# -----------------------------------------------------------------------------
AIRFLOW_UID=50000

# -----------------------------------------------------------------------------
# Autenticação GCP — apenas para desenvolvimento local
#
# Na VM (GCE e2-medium), o service account sa-airflow é associado à instância
# e o Airflow usa Application Default Credentials automaticamente.
# Não é necessário definir GOOGLE_APPLICATION_CREDENTIALS na VM.
#
# Para desenvolvimento local, aponte para o arquivo de chave da service account:
#   GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/sa-airflow-key.json
#
# NUNCA commite o arquivo de chave no repositório.
# -----------------------------------------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS=
